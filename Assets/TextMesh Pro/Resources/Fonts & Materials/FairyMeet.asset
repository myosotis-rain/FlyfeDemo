  m_Script: {fileID: 11500000, guid: 3365d426b4829484886591ba991c0a66, type: 3}
  m_Name: FairyMeet
  m_EditorClassIdentifier: Assembly-CSharp::DialogueConversation
  lines:
  - speakerName: Dandelion
    text: Please don't forget me...
    portrait: {fileID: -4128887083241503271, guid: 220c64372503c4060823dbc219db2db9, type: 3}
    customTypingSpeed: 0
    voiceBlip: {fileID: 0}
  - speakerName: Me
    text: There must be another way.
    portrait: {fileID: -2990309890484215505, guid: 78dccf96db139437c89f5deb1013cd51, type: 3}
    customTypingSpeed: 0
    voiceBlip: {fileID: 0}
  - speakerName: Dandelion
    text: "It's okay. We tried our best. \n"
    portrait: {fileID: -4128887083241503271, guid: 220c64372503c4060823dbc219db2db9, type: 3}
    customTypingSpeed: 0
    voiceBlip: {fileID: 0}
  - speakerName: Dandelion
    text: Don't miss me too much.
    portrait: {fileID: -4128887083241503271, guid: 220c64372503c4060823dbc219db2db9, type: 3}
    customTypingSpeed: 0
    voiceBlip: {fileID: 0}
